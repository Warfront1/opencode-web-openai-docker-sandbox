server {
    listen 80 default_server;
    listen [::]:80 default_server ipv6only=on;
    server_name _;

    # Prevent a massive file-leak from even leaving your machine
    client_max_body_size 50M;
    client_body_buffer_size 50M;

    resolver 127.0.0.11 ipv6=off valid=30s; # Docker DNS (IPv6 disabled to prevent resolution hangs)
    resolver_timeout 5s;

    # Extract upstream host for proper SNI and Host header
    # This is required for correct TLS (SNI) and routing with cloud providers
    set $base_url "${OPENAI_API_BASE}";
    set $upstream_host "";
    if ($base_url ~* "^https?://([^/]+)") {
        set $upstream_host $1;
    }

    # Match and capture everything after /api/v1/
    location ~ ^/api/v1/(.*)$ {
        set $upstream_path $1;
        set $upstream_url "${OPENAI_API_BASE}${upstream_path}";
        
        # Security: Prevent internal header leakage to the external provider
        proxy_pass_request_headers off;
        proxy_set_header Authorization "Bearer ${OPENAI_API_KEY}";
        proxy_set_header Content-Type "application/json";
        proxy_set_header Host $upstream_host;
        proxy_set_header User-Agent $http_user_agent;
        proxy_set_header Accept $http_accept;

        proxy_ssl_server_name on;
        proxy_ssl_name $upstream_host;
        proxy_ssl_session_reuse off; # Prevent hangs with certain upstream gateways
        
        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
        proxy_busy_buffers_size 256k;

        # Optimize for streaming LLM responses
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_cache off;
        gzip off;

        # Long timeouts for LLM responses
        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
        
        # Debug: Shows final upstream URL in response headers
        add_header X-Upstream-Url $upstream_url always;
        add_header X-Upstream-Host $upstream_host always;
        
        proxy_pass $upstream_url;
    }
}

server {
    listen 4096;
    listen [::]:4096;
    server_name _;

    location / {
        proxy_pass http://opencode-app:4096;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_buffering off; # Critical for real-time UI updates (SSE)
        proxy_request_buffering off;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}