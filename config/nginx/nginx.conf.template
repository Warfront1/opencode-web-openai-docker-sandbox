server {
    listen 80 default_server;
    listen [::]:80 default_server ipv6only=on;
    server_name _;

    # Prevent a massive file-leak from even leaving your machine
    client_max_body_size 1M;

    resolver 8.8.8.8 1.1.1.1 valid=300s;
    resolver_timeout 5s;

    location /api/v1/ {
        # Set the base URL variable first (required before any rewrite)
        set $upstream_url "${OPENAI_API_BASE}";
        
        # Strip the local /api/v1/ prefix before proxying
        rewrite ^/api/v1/(.*)$ /$1 break;

        proxy_pass_request_headers off;
        proxy_set_header Authorization "Bearer ${OPENAI_API_KEY}";
        proxy_set_header Content-Type "application/json";
        proxy_ssl_server_name on;
        
        # Debug header: Echoes the final URL being requested (visible in nginx logs)
        add_header X-Upstream-Url $upstream_url$uri always;
        
        proxy_pass $upstream_url;
    }
}

server {
    listen 4096;
    listen [::]:4096;
    server_name _;

    location / {
        proxy_pass http://opencode-app:4096;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}