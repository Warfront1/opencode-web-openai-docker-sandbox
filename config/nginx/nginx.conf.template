server {
    listen 80 default_server;
    listen [::]:80 default_server ipv6only=on;
    server_name _;

    # Prevent a massive file-leak from even leaving your machine
    client_max_body_size 10M;
    client_body_buffer_size 10M;

    resolver 8.8.8.8 1.1.1.1 valid=300s;
    resolver_timeout 5s;

    # Match and capture everything after /api/v1/
    location ~ ^/api/v1/(.*)$ {
        set $upstream_path $1;
        set $upstream_url "${OPENAI_API_BASE}${upstream_path}";
        
        proxy_pass_request_headers off;
        proxy_set_header Authorization "Bearer ${OPENAI_API_KEY}";
        proxy_set_header Content-Type "application/json";
        proxy_ssl_server_name on;
        
        # Long timeouts for LLM responses
        proxy_connect_timeout 60s;
        proxy_send_timeout 300s;
        proxy_read_timeout 300s;
        
        # Debug: Shows final upstream URL in response headers
        add_header X-Upstream-Url $upstream_url always;
        
        proxy_pass $upstream_url;
    }
}

server {
    listen 4096;
    listen [::]:4096;
    server_name _;

    location / {
        proxy_pass http://opencode-app:4096;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}